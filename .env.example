# ===========================================
# NeXPay WebApp - Environment Variables
# ===========================================
# Copy this file to .env.local for local development
# ===========================================

# ===========================================
# DATABASE (Prisma with SQLite)
# ===========================================
# Local development (SQLite file)
DATABASE_URL="file:./db/custom.db"

# For production (PostgreSQL/MySQL), use:
# DATABASE_URL="postgresql://user:password@localhost:5432/nexpay?schema=public"
# DATABASE_URL="mysql://user:password@localhost:3306/nexpay"

# ===========================================
# API CONFIGURATION
# ===========================================
# Backend API Base URL (Required)
NEXT_PUBLIC_API_URL="https://api-wallet.nextrustx.com/api/v1"

# ===========================================
# NEXTAUTH.JS (Optional - for additional auth)
# ===========================================
# NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
# NEXTAUTH_URL="http://localhost:3000"

# ===========================================
# ENVIRONMENT
# ===========================================
NODE_ENV="development"
